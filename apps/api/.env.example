# ── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
PORT=8000
DEBUG=false
CORS_ORIGINS=http://localhost:3000

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ── Orchestrator ──────────────────────────────────────────────────────────────
ORCHESTRATOR_URL=http://localhost:8001
ORCHESTRATOR_API_KEY=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── LLM Providers ────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── LangSmith (optional) ──────────────────────────────────────────────────────
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=luxai

# ── Alpaca Paper Trading ──────────────────────────────────────────────────────
# IMPORTANT: Use PAPER trading keys only.
# Get them from: https://app.alpaca.markets/paper-account
# The engine validates paper mode on connect and will refuse live keys.
ALPACA_API_KEY=
ALPACA_API_SECRET=

# ── Tradier (optional, future) ────────────────────────────────────────────────
# Sandbox mode is always enforced (TRADIER_SANDBOX=true)
TRADIER_API_KEY=
TRADIER_SANDBOX=true

# ── OpenTelemetry (optional) ─────────────────────────────────────────────────
OTLP_ENDPOINT=
