# ==============================================================================
# LuxAI Operating System — Unified Environment Configuration
# ==============================================================================
# Copy this file to `.env` in the root directory to populate all services.
# 
# WARNING: Never commit real API keys or secrets to version control.
# ==============================================================================

# ── General ───────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:8001

# ── Supabase (Database & Auth) ────────────────────────────────────────────────
# These must match your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ── API Gateway (FastAPI) ─────────────────────────────────────────────────────
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# ── Orchestrator (LangGraph) ──────────────────────────────────────────────────
ORCHESTRATOR_PORT=8001
ORCHESTRATOR_API_KEY=change-me-in-production
API_SERVICE_URL=http://api:8000

# ── Upstash Redis ─────────────────────────────────────────────────────────────
# This project uses Upstash Redis exclusively — no local Redis.
# UPSTASH_REDIS_URL: rediss:// connection string from console.upstash.com → Connect tab
# UPSTASH_REDIS_TOKEN: REST auth token from console.upstash.com → REST API tab
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# ── LLM Providers ─────────────────────────────────────────────────────────────
# At least one provider is required for the orchestrator to function
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEFAULT_MODEL=claude-sonnet-4-6

# ── Paper Trading (Alpaca) ────────────────────────────────────────────────────
# IMPORTANT: Use PAPER trading keys only. The engine will refuse live keys.
# Get them from: https://app.alpaca.markets/paper-account
ALPACA_API_KEY=
ALPACA_API_SECRET=

# ── Market Data & Options (Tradier) ───────────────────────────────────────────
# Get sandbox keys from: https://developer.tradier.com/
# Set TRADIER_SANDBOX=false and use production keys only after full shadow review.
TRADIER_API_KEY=
TRADIER_SANDBOX=true

# ── Observability & Tracing (Optional) ────────────────────────────────────────
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=luxai-os
OTLP_ENDPOINT=
