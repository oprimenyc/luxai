# ══════════════════════════════════════════════════════════════════════════════
# LuxAI — Root environment variables example
# Copy service-specific .env.example files into their directories.
# ══════════════════════════════════════════════════════════════════════════════

# ── Web (apps/web/.env.local) ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── API (apps/api/.env) ───────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
REDIS_URL=redis://localhost:6379/0

# ── Orchestrator (apps/orchestrator/.env) ─────────────────────────────────
ORCHESTRATOR_OPENAI_API_KEY=sk-...
ORCHESTRATOR_ANTHROPIC_API_KEY=sk-ant-...
ORCHESTRATOR_API_KEY=change-me-in-production
ORCHESTRATOR_REDIS_URL=redis://localhost:6379/1

# ── LangSmith (optional) ─────────────────────────────────────────────────
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=luxai

# ── Cloudflare (CI/CD) ───────────────────────────────────────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
