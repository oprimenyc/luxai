#!/bin/sh

# Run typecheck before pushing to prevent broken code reaching CI
echo "Running typecheck before push..."
pnpm run typecheck

# Run Python type checks if api or orchestrator files changed
if git diff --name-only HEAD@{1} HEAD 2>/dev/null | grep -q "^apps/api/"; then
  echo "Running mypy on apps/api..."
  cd apps/api && python -m mypy src && cd ../..
fi

if git diff --name-only HEAD@{1} HEAD 2>/dev/null | grep -q "^apps/orchestrator/"; then
  echo "Running mypy on apps/orchestrator..."
  cd apps/orchestrator && python -m mypy src && cd ../..
fi
